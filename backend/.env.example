# ── 필수 ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...          # OpenAI API 키 (STORY_TEST_MODE=true면 불필요)
SECRET_KEY=your-secret-key     # JWT 서명용 임의 문자열

# ── 선택 (없으면 mock 모드로 전체 플로우 동작) ────────────────────────────────
SWEETBOOK_API_KEY=              # SweetBook API 키
AWS_ACCESS_KEY_ID=              # S3 이미지 업로드용
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=

# ── 테스트 모드 (기본값 true) ─────────────────────────────────────────────────
STORY_TEST_MODE=true            # true: OpenAI 없이 더미 스토리 반환
IMAGE_TEST_MODE=true            # true: DALL-E 없이 로컬 샘플 이미지 사용

# ── DB ────────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./storybook.db

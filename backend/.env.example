# ───────────────────────────────────────────────
# AI StoryBook — 백엔드 환경 변수 예시
# 사용법: 이 파일을 복사해서 .env 로 저장하세요
#   cp .env.example .env
# ───────────────────────────────────────────────

# ── OpenAI ──────────────────────────────────────
# GPT 스토리 생성 및 DALL-E 이미지 생성에 사용됩니다.
OPENAI_API_KEY= OPEN_API_KEY 입력
OPENAI_MODEL=gpt-4o-mini

# ── SweetBook ───────────────────────────────────
# 실제 SweetBook 계정이 없어도 실행 가능합니다.
# API 호출이 실패하면 자동으로 mock 데이터를 사용합니다.
SWEETBOOK_API_KEY=SB_DUMMY_KEY

# ── AWS S3 ──────────────────────────────────────
# IMAGE_TEST_MODE=true 이면 S3 업로드를 건너뛰고 더미 이미지 URL을 사용합니다.
# 로컬 실행 시 아래 값을 비워두거나 그대로 사용하세요.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=

# ── 이미지 테스트 모드 ─────────────────────────────
# true: DALL-E / S3 를 호출하지 않고 더미 이미지 URL 사용 (로컬 권장)
# false: 실제 DALL-E 로 이미지를 생성하고 S3 에 저장
IMAGE_TEST_MODE=true

# ── 데이터베이스 ────────────────────────────────────
DATABASE_URL=sqlite:///./storybook.db

# ── 인증 ────────────────────────────────────────────
# 아무 랜덤 문자열로 바꿔도 됩니다.
SECRET_KEY=change-me-to-any-random-string
